							"enableLogging": true,
							"storeSettings": {
								"type": "AzureBlobFSReadSettings",
								"recursive": true,
								"wildcardFileName": "*.csv",
								"enablePartitionDiscovery": false
							}
						}
					}
				],
				"policy": {
					"elapsedTimeMetric": {}
				},
				"annotations": [],
				"lastPublishTime": "2026-03-22T09:55:57Z"
			},
			"dependsOn": [
				"[concat(variables('factoryId'), '/datasets/DS_MULTI_CSV')]",
				"[concat(variables('factoryId'), '/datasets/DS_MULTI_PARQUET')]"
