		"KV_OnPremSQLDB_properties_typeProperties_baseUrl": {
			"type": "string",
			"defaultValue": "https://keyvaultonpremsqldb.vault.azure.net/"
		},
		"KV_OnPremSQL_DB_Secret_properties_typeProperties_baseUrl": {
			"type": "string",
			"defaultValue": "https://keyvaultonpremsqldb.vault.azure.net/"
		},
		"LS_ADLS_PARQUET_properties_typeProperties_url": {
			"type": "string",
			"defaultValue": "https://adlsdevfinus004.dfs.core.windows.net"
		},
		"LS_API_ADLS_properties_typeProperties_url": {
			"type": "string",
			"defaultValue": "https://retoolapi.dev/5yDVOt/data"
		},
		"LS_CSV_INPUT_properties_typeProperties_url": {
			"type": "string",
			"defaultValue": "https://adlsdevfinus004.dfs.core.windows.net/"
		},
		"LS_CSV_PARQUET_properties_typeProperties_url": {
			"type": "string",
			"defaultValue": "https://adlsdevfinus004.dfs.core.windows.net/"
		},
		"LS_FILE_LIST_properties_typeProperties_url": {
			"type": "string",
			"defaultValue": "https://adlsdevfinus004.dfs.core.windows.net/"
		},
		"LS_MULTI_CSV_properties_typeProperties_url": {
			"type": "string",
			"defaultValue": "https://adlsdevfinus004.dfs.core.windows.net/"
		},
		"LS_SQL_TABLE_PARQUET_properties_typeProperties_url": {
			"type": "string",
			"defaultValue": "https://adlsdevfinus004.dfs.core.windows.net/"
		},
		"LS_VALIDATE_FILE_EXIST_properties_typeProperties_url": {
			"type": "string",
			"defaultValue": "https://adlsdevfinus004.dfs.core.windows.net/"
		}
	},
	"variables": {
		"factoryId": "[concat('Microsoft.DataFactory/factories/', parameters('factoryName'))]"
	},
	"resources": [
		{
			"name": "[concat(parameters('factoryName'), '/KV_AzureSQL_Secret')]",
			"type": "Microsoft.DataFactory/factories/linkedServices",
			"apiVersion": "2018-06-01",
			"properties": {
				"annotations": [],
				"type": "AzureKeyVault",
				"typeProperties": {
					"baseUrl": "[parameters('KV_AzureSQL_Secret_properties_typeProperties_baseUrl')]"
				}
			},
			"dependsOn": []
